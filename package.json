{
  "name": "@falkura-pet/games-collection",
  "version": "0.1.0",
  "scripts": {
    "assemble": "bun i && bunx --bun moon run '#game:build' -f && bunx --bun moon run games-wrapper:build",
    "postinstall": "bun add -g @moonrepo/cli"
  },
  "devDependencies": {
    "@assetpack/core": "^1.5.0",
    "@moonrepo/cli": "^2.1.3",
    "@rslib/core": "^0.20.0",
    "@rspack/cli": "^1.7.2",
    "@rspack/core": "^1.7.2",
    "@types/bun": "^1.3.5",
    "typescript": "^5.9.3"
  },
  "trustedDependencies": [
    "@moonrepo/cli"
  ],
  "workspaces": [
    "packages/*",
    "games/*"
  ]
}